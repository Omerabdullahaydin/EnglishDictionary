import React, { useMemo, useState, useEffect } from 'react';
import { StyleSheet, TextInput, TouchableOpacity, Modal, ScrollView, View } from 'react-native';
import { Link } from 'expo-router';
import AsyncStorage from '@react-native-async-storage/async-storage';
import { useAuth } from '../../contexts/auth-context';

import { ThemedText } from '@/components/themed-text';
import { ThemedView } from '@/components/themed-view';
import { useWords } from '../../contexts/word-context';

export default function HomeScreen() {
  const {
    words,
    addFolder,
    setSearchQuery,
    setSelectedCategory,
  } = useWords();

  const { isLoggedIn, login, register, logout } = useAuth();

  const [authModalVisible, setAuthModalVisible] = useState(false);
  const [authEmail, setAuthEmail] = useState('');
  const [authPassword, setAuthPassword] = useState('');
  const [isRegisterMode, setIsRegisterMode] = useState(false);
  const [authPurpose, setAuthPurpose] = useState<'login'|'register'|'pinSet'|'pinEnter'>('login');
  const [translateQuery, setTranslateQuery] = useState('');

  // şifre (pin) depolama; giriş/kayıtta da kullanılıyor
  const [passcode, setPasscode] = useState<string | null>(null);
  const [pinInput, setPinInput] = useState('');

  useEffect(() => {
    AsyncStorage.getItem('@passcode').then(p => {
      if (p) setPasscode(p);
    });
  }, []);

  useEffect(() => {
    setSearchQuery('');
  }, [setSearchQuery]);

  // yardımcı: klasör ekleme yalnızca girişli kullanıcıya açık
  const onAddFolderPress = () => {
    if (isLoggedIn) {
      setFolderModalVisible(true);
    } else {
      // giriş yapmaları için modal göster
      setIsRegisterMode(false);
      setAuthPurpose('login');
      setAuthModalVisible(true);
    }
  };


  // giriş/kayıt yazı bağlantıları göster
  const authButtons = !isLoggedIn && (
    <View style={styles.authRowRight}>
      <TouchableOpacity
        onPress={() => {
          setIsRegisterMode(false);
          setAuthPurpose('login');
          setAuthModalVisible(true);
        }}
      >
        <ThemedText style={styles.authText}>Giriş Yap</ThemedText>
      </TouchableOpacity>
      <TouchableOpacity
        onPress={() => {
          setIsRegisterMode(true);
          setAuthPurpose('register');
          setAuthModalVisible(true);
        }}
      >
        <ThemedText style={[styles.authText, { marginLeft: 15 }]}>Kayıt Ol</ThemedText>
      </TouchableOpacity>
    </View>
  );

  const [userMenuVisible, setUserMenuVisible] = useState(false);

  const userMenu = isLoggedIn && (
    <View style={styles.userMenuContainer}>
      <TouchableOpacity onPress={() => setUserMenuVisible(!userMenuVisible)}>
        <ThemedText style={[styles.authText, styles.userIcon]}>👤</ThemedText>
      </TouchableOpacity>
      {userMenuVisible && (
        <View style={styles.userMenu}>
          <TouchableOpacity
            onPress={() => { logout(); setUserMenuVisible(false); }}
            style={styles.userMenuItem}
          >
            <ThemedText>Çıkış Yap</ThemedText>
          </TouchableOpacity>
          <TouchableOpacity
            onPress={() => { /* profile edit action */ setUserMenuVisible(false); }}
            style={styles.userMenuItem}
          >
            <ThemedText>Profili Düzenle</ThemedText>
          </TouchableOpacity>
        </View>
      )}
      )}
    </View>
  );


  const translationMaps = useMemo(() => {
    const addToMap = (map: Map<string, string[]>, key: string, value: string) => {
      const list = map.get(key) ?? [];
      if (!list.includes(value)) list.push(value);
      map.set(key, list);
    };

    const englishMap = new Map<string, string[]>();
    const turkishMap = new Map<string, string[]>();

    words.forEach(word => {
      addToMap(englishMap, word.english.toLowerCase(), word.turkish);
      addToMap(turkishMap, word.turkish.toLowerCase(), word.english);
    });

    return { englishMap, turkishMap };
  }, [words]);

  const translationResult = useMemo(() => {
    const rawQuery = translateQuery.trim();
    if (!rawQuery) return null;

    const { englishMap, turkishMap } = translationMaps;
    const wordPattern = /[A-Za-z\u00C7\u011E\u0130\u00D6\u015E\u00DC\u00E7\u011F\u0131\u00F6\u015F\u00FC']+/;
    const parts = rawQuery.match(/[A-Za-z\u00C7\u011E\u0130\u00D6\u015E\u00DC\u00E7\u011F\u0131\u00F6\u015F\u00FC']+|[^A-Za-z\u00C7\u011E\u0130\u00D6\u015E\u00DC\u00E7\u011F\u0131\u00F6\u015F\u00FC']+/g) ?? [rawQuery];

    if (parts.length === 1 && wordPattern.test(parts[0])) {
      const key = parts[0].toLowerCase();
      const candidates = englishMap.get(key) ?? turkishMap.get(key) ?? [];
      if (candidates.length === 0) return null;
      return candidates.join(', ');
    }

    const translated = parts.map(part => {
      if (!wordPattern.test(part)) return part;
      const key = part.toLowerCase();
      const fromEnglish = englishMap.get(key);
      if (fromEnglish && fromEnglish.length > 0) return fromEnglish[0];
      const fromTurkish = turkishMap.get(key);
      if (fromTurkish && fromTurkish.length > 0) return fromTurkish[0];
      return part;
    });

    const result = translated.join('');
    return result.trim() ? result : null;

  }, [translateQuery, translationMaps]);

  const suggestions = useMemo(() => {
    const rawQuery = translateQuery.trim();
    if (!rawQuery || rawQuery.includes(' ')) return [];
    const query = rawQuery.toLowerCase();

    const { englishMap, turkishMap } = translationMaps;
    const combined = new Map<string, string[]>();

    englishMap.forEach((values, key) => {
      if (key.startsWith(query)) combined.set(key, values);
    });

    turkishMap.forEach((values, key) => {
      if (key.startsWith(query)) combined.set(key, values);
    });

    return Array.from(combined.entries())
      .slice(0, 10)
      .map(([word, meanings]) => ({
        word,
        meaning: meanings.join(', '),
      }));
  }, [translateQuery, translationMaps]);


  const [folderModalVisible, setFolderModalVisible] = useState(false);
  const [folderName, setFolderName] = useState('');

  return (
    <ThemedView style={styles.container}>
      {userMenu}
      {authButtons}
      <ThemedText type="title" style={styles.title}>İngilizce Sözlük</ThemedText>

      <TextInput
        style={styles.searchInput}
        placeholder="Kelimeyi çevir..."
        value={translateQuery}
        onChangeText={setTranslateQuery}
      />

      {suggestions.length > 0 && (
        <View style={styles.suggestionsBox}>
          {suggestions.map(item => (
            <TouchableOpacity
              key={item.word}
              style={styles.suggestionItem}
              onPress={() => setTranslateQuery(item.word)}
            >
              <ThemedText style={styles.suggestionWord}>{item.word}</ThemedText>
              <ThemedText style={styles.suggestionMeaning}>{item.meaning}</ThemedText>
            </TouchableOpacity>
          ))}
        </View>
      )}

      {translationResult !== null && (
        <View style={styles.translationBox}>
          <ThemedText style={styles.translationLabel}>Çeviri:</ThemedText>
          <ThemedText style={styles.translationText}>{translationResult}</ThemedText>
        </View>
      )}

        <View style={styles.modalOverlay}>
                      {isRegisterMode ? 'Kayıt' : 'Giriş'}
                    </ThemedText>
                  </TouchableOpacity>
                  <TouchableOpacity
                    style={[styles.addButton, { flex: 1, marginLeft: 10, backgroundColor: '#ccc' }]}
                    onPress={() => {
                      setAuthModalVisible(false);
                      setAuthEmail('');
                      setAuthPassword('');
                    }}
                  >
                    <ThemedText style={styles.addButtonText}>İptal</ThemedText>
                  </TouchableOpacity>
                </View>
                <TouchableOpacity
                  onPress={() => setIsRegisterMode(!isRegisterMode)}
                  style={{ marginTop: 10 }}
                >
                  <ThemedText style={{ textAlign: 'center' }}>
                    {isRegisterMode ? 'Zaten hesabın var mı? Giriş yap' : 'Hesabın yok mu? Kayıt ol'}
                  </ThemedText>
                </TouchableOpacity>
              </>
            ) : authPurpose === 'pinSet' ? (
              <>
                <ThemedText type="title" style={styles.modalTitle}>Şifre Oluştur</ThemedText>
                <TextInput
                  style={styles.input}
                  placeholder="4 haneli PIN"
                  value={pinInput}
                  onChangeText={setPinInput}
                  secureTextEntry
                  keyboardType="numeric"
                />
                <View style={styles.modalButtons}>
                  <TouchableOpacity
                    style={[styles.addButton, { flex: 1 }]}
                    onPress={() => {
                      if (pinInput.trim()) {
                        AsyncStorage.setItem('@passcode', pinInput);
                        setPasscode(pinInput);
                        setAuthModalVisible(false);
                        setFolderModalVisible(true);
                      }
                    }}
                  >
                    <ThemedText style={styles.addButtonText}>Kaydet</ThemedText>
                  </TouchableOpacity>
                  <TouchableOpacity
                    style={[styles.addButton, { flex: 1, marginLeft: 10, backgroundColor: '#ccc' }]}
                    onPress={() => {
                      setAuthModalVisible(false);
                      setPinInput('');
                    }}
                  >
                    <ThemedText style={styles.addButtonText}>İptal</ThemedText>
                  </TouchableOpacity>
                </View>
              </>
            ) : (
              <>
                <ThemedText type="title" style={styles.modalTitle}>Şifre Giriniz</ThemedText>
                <TextInput
                  style={styles.input}
                  placeholder="PIN"
                  value={pinInput}
                  onChangeText={setPinInput}
                  secureTextEntry
                  keyboardType="numeric"
                />
                <View style={styles.modalButtons}>
                  <TouchableOpacity
                    style={[styles.addButton, { flex: 1 }]}
                    onPress={() => {
                      if (pinInput === passcode) {
                        setAuthModalVisible(false);
                        setFolderModalVisible(true);
                      } else {
                        Alert.alert('Hata', 'Şifre yanlış');
                        setPinInput('');
                      }
                    }}
                  >
                    <ThemedText style={styles.addButtonText}>Doğrula</ThemedText>
                  </TouchableOpacity>
                  <TouchableOpacity
                    style={[styles.addButton, { flex: 1, marginLeft: 10, backgroundColor: '#ccc' }]}
                    onPress={() => {
                      setAuthModalVisible(false);
                      setPinInput('');
                    }}
                  >
                    <ThemedText style={styles.addButtonText}>İptal</ThemedText>
                  </TouchableOpacity>
                </View>
              </>
            )}
          </View>
        </View>
      </Modal>

      <View style={styles.actionsRow}>
        <Link href="/modal" asChild>
          <TouchableOpacity style={styles.addButton}>
            <ThemedText style={styles.addButtonText}>+ Yeni Kelime</ThemedText>
          </TouchableOpacity>
        </Link>
        <TouchableOpacity
          style={[styles.addButton, styles.folderButton]}
          onPress={onAddFolderPress}
        >
          <ThemedText style={styles.addButtonText}>+ Klasör</ThemedText>
        </TouchableOpacity>
      </View>
    </ThemedView>
  );
}

